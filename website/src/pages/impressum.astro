---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Impressum — Jakob Menger"
  description="Impressum der Website jakobmenger.de gemäß § 5 TMG."
>
  <!-- Nav -->
  <header
    class="fixed top-0 left-0 right-0 z-50 px-6 md:px-12 py-4 flex items-center justify-between"
    style="background: rgba(5,12,24,0.9); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(201,168,76,0.1);"
  >
    <a
      href="/"
      class="font-headline text-2xl tracking-widest transition-colors duration-200"
      style="color: #C9A84C;"
      aria-label="Zurück zur Startseite"
    >JM</a>
    <a
      href="/"
      class="inline-flex items-center gap-2 text-sm font-medium transition-colors duration-200"
      style="color: rgba(255,255,255,0.6);"
      onmouseover="this.style.color='#C9A84C'"
      onmouseout="this.style.color='rgba(255,255,255,0.6)'"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Zurück
    </a>
  </header>

  <!-- Main -->
  <main style="background: #0f172a; min-height: 100vh; padding-top: 6rem;">

    <!-- Hero -->
    <div class="max-w-3xl mx-auto px-6 md:px-12 pt-12 pb-4">
      <span
        class="inline-block text-xs font-semibold tracking-[0.2em] uppercase mb-4 px-3 py-1 rounded-full"
        style="background: rgba(201,168,76,0.1); color: #C9A84C; border: 1px solid rgba(201,168,76,0.2);"
      >Rechtliches</span>
      <h1
        class="font-headline text-[clamp(3rem,10vw,6rem)] leading-none tracking-wide"
        style="color: #ffffff;"
      >
        IMPRES<span style="color: #C9A84C;">SUM</span>
      </h1>
      <div
        class="mt-4 h-px w-24"
        style="background: linear-gradient(90deg, #C9A84C, transparent);"
        aria-hidden="true"
      ></div>
    </div>

    <!-- Content -->
    <div class="max-w-3xl mx-auto px-6 md:px-12 py-12">
      <div
        class="rounded-2xl p-8 md:p-12 space-y-10"
        style="background: #16213b; border: 1px solid rgba(201,168,76,0.12);"
      >

        <!-- Angaben nach §5 TMG -->
        <section>
          <h2
            class="font-headline text-2xl tracking-widest mb-4"
            style="color: #C9A84C;"
          >ANGABEN GEMÄSS § 5 TMG</h2>
          <p class="text-white leading-relaxed">
            Jakob Menger<br />
            Am Mühlhügel 8<br />
            95179 Geroldsgrün<br />
            Deutschland
          </p>
        </section>

        <div class="h-px" style="background: rgba(201,168,76,0.1);"></div>

        <!-- Kontakt -->
        <section>
          <h2
            class="font-headline text-2xl tracking-widest mb-4"
            style="color: #C9A84C;"
          >KONTAKT</h2>
          <p class="text-white leading-relaxed">
            E-Mail:&ensp;
            <a
              href="mailto:jakob.menger@icloud.com"
              class="transition-colors duration-200"
              style="color: #C9A84C;"
              onmouseover="this.style.color='#E8C87A'"
              onmouseout="this.style.color='#C9A84C'"
            >jakob.menger@icloud.com</a>
          </p>
        </section>

        <div class="h-px" style="background: rgba(201,168,76,0.1);"></div>

        <!-- Hinweis zur privaten Nutzung -->
        <section>
          <h2
            class="font-headline text-2xl tracking-widest mb-4"
            style="color: #C9A84C;"
          >HINWEIS ZUR WEBSITE</h2>
          <p class="leading-relaxed" style="color: rgba(255,255,255,0.7);">
            Diese Website ist eine private, nicht-kommerzielle Präsenz. Es werden keine
            Produkte oder Dienstleistungen entgeltlich angeboten. Die Inhalte dienen
            ausschließlich zur persönlichen Vorstellung und zum Austausch.
          </p>
        </section>

        <div class="h-px" style="background: rgba(201,168,76,0.1);"></div>

        <!-- Haftung für Inhalte -->
        <section>
          <h2
            class="font-headline text-2xl tracking-widest mb-4"
            style="color: #C9A84C;"
          >HAFTUNG FÜR INHALTE</h2>
          <p class="leading-relaxed" style="color: rgba(255,255,255,0.7);">
            Als Diensteanbieter bin ich gemäß § 7 Abs. 1 TMG für eigene Inhalte auf dieser
            Website nach den allgemeinen Gesetzen verantwortlich. Nach §§ 8 bis 10 TMG bin
            ich als Diensteanbieter jedoch nicht verpflichtet, übermittelte oder gespeicherte
            fremde Informationen zu überwachen oder nach Umständen zu forschen, die auf eine
            rechtswidrige Tätigkeit hinweisen.
          </p>
          <p class="leading-relaxed mt-4" style="color: rgba(255,255,255,0.7);">
            Verpflichtungen zur Entfernung oder Sperrung der Nutzung von Informationen nach
            den allgemeinen Gesetzen bleiben hiervon unberührt. Eine diesbezügliche Haftung
            ist jedoch erst ab dem Zeitpunkt der Kenntnis einer konkreten Rechtsverletzung
            möglich. Bei Bekanntwerden von entsprechenden Rechtsverletzungen werde ich diese
            Inhalte umgehend entfernen.
          </p>
        </section>

        <div class="h-px" style="background: rgba(201,168,76,0.1);"></div>

        <!-- Haftung für Links -->
        <section>
          <h2
            class="font-headline text-2xl tracking-widest mb-4"
            style="color: #C9A84C;"
          >HAFTUNG FÜR LINKS</h2>
          <p class="leading-relaxed" style="color: rgba(255,255,255,0.7);">
            Mein Angebot enthält Links zu externen Websites Dritter, auf deren Inhalte ich
            keinen Einfluss habe. Deshalb kann ich für diese fremden Inhalte auch keine
            Gewähr übernehmen. Für die Inhalte der verlinkten Seiten ist stets der jeweilige
            Anbieter oder Betreiber der Seiten verantwortlich.
          </p>
          <p class="leading-relaxed mt-4" style="color: rgba(255,255,255,0.7);">
            Die verlinkten Seiten wurden zum Zeitpunkt der Verlinkung auf mögliche
            Rechtsverstöße überprüft. Rechtswidrige Inhalte waren zum Zeitpunkt der
            Verlinkung nicht erkennbar. Eine permanente inhaltliche Kontrolle der verlinkten
            Seiten ist jedoch ohne konkrete Anhaltspunkte einer Rechtsverletzung nicht
            zumutbar. Bei Bekanntwerden von Rechtsverletzungen werde ich derartige Links
            umgehend entfernen.
          </p>
        </section>

        <div class="h-px" style="background: rgba(201,168,76,0.1);"></div>

        <!-- Urheberrecht -->
        <section>
          <h2
            class="font-headline text-2xl tracking-widest mb-4"
            style="color: #C9A84C;"
          >URHEBERRECHT</h2>
          <p class="leading-relaxed" style="color: rgba(255,255,255,0.7);">
            Die durch mich erstellten Inhalte und Werke auf diesen Seiten unterliegen dem
            deutschen Urheberrecht. Die Vervielfältigung, Bearbeitung, Verbreitung und jede
            Art der Verwertung außerhalb der Grenzen des Urheberrechtes bedürfen meiner
            schriftlichen Zustimmung. Downloads und Kopien dieser Seite sind nur für den
            privaten, nicht kommerziellen Gebrauch gestattet.
          </p>
          <p class="leading-relaxed mt-4" style="color: rgba(255,255,255,0.7);">
            Soweit die Inhalte auf dieser Seite nicht von mir erstellt wurden, werden die
            Urheberrechte Dritter beachtet. Insbesondere werden Inhalte Dritter als solche
            gekennzeichnet. Solltest du trotzdem auf eine Urheberrechtsverletzung aufmerksam
            werden, bitte ich um einen entsprechenden Hinweis. Bei Bekanntwerden von
            Rechtsverletzungen werde ich derartige Inhalte umgehend entfernen.
          </p>
        </section>

      </div>

      <!-- Back link -->
      <div class="mt-10 text-center">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-sm font-medium transition-colors duration-200"
          style="color: rgba(255,255,255,0.5);"
          onmouseover="this.style.color='#C9A84C'"
          onmouseout="this.style.color='rgba(255,255,255,0.5)'"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Zurück zur Startseite
        </a>
      </div>
    </div>

  </main>

  <!-- Footer -->
  <footer
    class="py-6 px-6 md:px-12 text-center text-sm"
    style="background: #0e152a; border-top: 1px solid rgba(201,168,76,0.1); color: rgba(255,255,255,0.4);"
  >
    © {new Date().getFullYear()} Jakob Menger &nbsp;·&nbsp;
    <a href="/impressum" style="color: #C9A84C;">Impressum</a>
    &nbsp;·&nbsp;
    <a href="/datenschutz" class="transition-colors duration-200" style="color: rgba(255,255,255,0.4);"
      onmouseover="this.style.color='#C9A84C'" onmouseout="this.style.color='rgba(255,255,255,0.4)'">Datenschutz</a>
  </footer>

</BaseLayout>
