---
const cards = [
  {
    title: 'E-Commerce & Marketing',
    body: 'Ich studiere E-Commerce an der THWS und arbeite als Online Marketer bei der Top Leader Academy. SEO, Content-Strategie, Conversion — das ist mein Spielfeld.',
    tags: ['SEO', 'Content', 'Conversion'],
    iconPath: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z',
  },
  {
    title: 'Video & Content',
    body: 'Mit DaVinci Resolve schneide ich Videos für die Top Leader Academy und die JUMIKO Franken. Storytelling durch bewegte Bilder — das begeistert mich.',
    tags: ['DaVinci Resolve', 'Storytelling', 'Podcast'],
    iconPath: 'M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z',
  },
  {
    title: 'Mission & Ehrenamt',
    body: 'Bei der JUMIKO Franken und der Jugendarbeit des Dekanats Naila bringe ich digitale Skills und Herz zusammen — weil Kirche und Kreativität kein Widerspruch sind.',
    tags: ['JUMIKO', 'Jugendarbeit', 'Community'],
    iconPath: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
  },
];
---

<section
  id="was-ich-tue"
  class="py-28 md:py-36"
  style="background: #F7F8FF;"
  aria-labelledby="was-ich-tue-headline"
>
  <div class="max-w-7xl mx-auto px-6 md:px-12">

    <!-- Header -->
    <div class="text-center mb-20">
      <div class="fade-up mb-5">
        <span class="text-xs font-semibold tracking-[0.22em] uppercase" style="color: #C9A84C;">Was ich mache</span>
      </div>
      <h2
        id="was-ich-tue-headline"
        class="font-headline text-[clamp(3rem,8vw,6rem)] leading-none text-[#050C18] fade-up"
        style="transition-delay: 0.06s;"
      >
        WAS ICH<br />
        <span style="background: linear-gradient(90deg, #C9A84C, #8B6914); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">TUE</span>
      </h2>
      <p class="mt-5 max-w-lg mx-auto text-lg font-light fade-up" style="color: rgba(5,12,24,0.5); transition-delay: 0.1s;">
        Drei Bereiche, ein Antrieb — digitales Business mit echtem Herz.
      </p>
    </div>

    <!-- Cards -->
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
      {cards.map((card, i) => (
        <article
          class="card-hover fade-up rounded-3xl p-8 flex flex-col bg-white"
          style={`box-shadow: 0 2px 20px rgba(8,31,91,0.06), 0 8px 40px rgba(8,31,91,0.04); transition-delay: ${i * 0.08}s;`}
        >
          <!-- Icon -->
          <div
            class="w-14 h-14 rounded-2xl flex items-center justify-center mb-7"
            style="background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.25);"
            aria-hidden="true"
          >
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="#C9A84C" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d={card.iconPath} />
            </svg>
          </div>

          <!-- Title -->
          <h3 class="font-headline text-2xl mb-3" style="color: #050C18;">{card.title}</h3>

          <!-- Body -->
          <p class="text-base leading-relaxed flex-1 font-light" style="color: rgba(5,12,24,0.6);">{card.body}</p>

          <!-- Tags -->
          <div class="mt-7 flex flex-wrap gap-2">
            {card.tags.map((tag) => (
              <span
                class="px-3 py-1 rounded-full text-xs font-medium"
                style="background: rgba(8,31,91,0.06); color: #1A3A7A;"
              >
                {tag}
              </span>
            ))}
          </div>

          <!-- Accent line -->
          <div
            class="mt-7 h-px"
            style="background: linear-gradient(90deg, #081F5B22, #C9A84C66, transparent);"
            aria-hidden="true"
          ></div>
        </article>
      ))}
    </div>

  </div>
</section>
