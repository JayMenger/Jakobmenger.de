---
const year = new Date().getFullYear();
---

<footer
  class="py-8 px-6 md:px-12"
  style="background: #040A18; border-top: 1px solid rgba(201,168,76,0.1);"
  role="contentinfo"
>
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-text-muted">

    <!-- Copyright -->
    <span>
      © {year} Jakob Menger · <a
        href="https://jakobmenger.de"
        class="hover:text-accent-primary transition-colors duration-200"
      >jakobmenger.de</a>
    </span>

    <!-- JESUS 1ST -->
    <span
      class="font-bold tracking-[0.2em] text-xs uppercase"
      style="color: #C9A84C; opacity: 0.8;"
    >
      JESUS 1ST
    </span>

    <!-- Legal links + back to top -->
    <div class="flex items-center gap-4">
      <a
        href="/impressum"
        class="hover:text-accent-primary transition-colors duration-200"
      >Impressum</a>
      <span style="color: rgba(201,168,76,0.3);">·</span>
      <a
        href="/datenschutz"
        class="hover:text-accent-primary transition-colors duration-200"
      >Datenschutz</a>
      <span style="color: rgba(201,168,76,0.3);">·</span>
      <a
        href="#hero"
        class="hover:text-accent-primary transition-colors duration-200 flex items-center gap-1.5"
        aria-label="Zurück nach oben"
      >
        <svg class="w-3.5 h-3.5 rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
        Nach oben
      </a>
    </div>

  </div>
</footer>
