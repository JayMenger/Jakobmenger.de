---
const marketingSkills = [
  'SEO / SEA',
  'Content Marketing',
  'Web Analytics',
  'Social Media Marketing',
  'App Design',
  'Online Marketing',
  'Usability',
  'Accessibility',
];

const creativeSkills = [
  'DaVinci Resolve',
  'Video Editing',
  'Storytelling',
  'Podcast-Produktion',
  'Social Content',
  'Community Building',
];
---

<section
  id="skills"
  class="relative py-28 md:py-36 overflow-hidden"
  style="background: #0f172a;"
  aria-labelledby="skills-headline"
>
  <!-- Atmosphäre -->
  <div
    class="absolute pointer-events-none"
    style="top: 0; right: -10%; width: 600px; height: 600px; background: radial-gradient(circle, rgba(201,168,76,0.06) 0%, transparent 65%); filter: blur(70px);"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12">

    <!-- Header (AI-Stil) -->
    <div class="mb-14 fade-up">
      <span class="skills-label">Was ich kann</span>
      <h2
        id="skills-headline"
        class="skills-title mt-3"
        style="transition-delay: 0.06s;"
      >
        Werkzeuge &<br />
        <em>Fähigkeiten.</em>
      </h2>
    </div>

    <!-- Two columns (AI-Stil mit Skill-Cloud) -->
    <div class="grid md:grid-cols-2 gap-0 md:divide-x" style="border-color: rgba(201,168,76,0.12);">

      <div class="fade-up md:pr-16" style="transition-delay: 0.1s;">
        <div class="flex items-center gap-3 mb-6 pb-5" style="border-bottom: 1px solid rgba(201,168,76,0.15);">
          <span class="skill-group-dot-dark" aria-hidden="true"></span>
          <h3 class="text-white font-semibold text-sm tracking-[0.08em] uppercase">E-Commerce & Marketing</h3>
        </div>
        <div class="flex flex-wrap gap-3">
          {marketingSkills.map((skill) => (
            <span class="skill-pill">
              <span class="skill-pill-dot" aria-hidden="true"></span>
              {skill}
            </span>
          ))}
        </div>
      </div>

      <div class="fade-up md:pl-16 mt-12 md:mt-0" style="transition-delay: 0.15s;">
        <div class="flex items-center gap-3 mb-6 pb-5" style="border-bottom: 1px solid rgba(201,168,76,0.15);">
          <span class="skill-group-dot-dark skill-group-dot-dark--secondary" aria-hidden="true"></span>
          <h3 class="text-white font-semibold text-sm tracking-[0.08em] uppercase">Content & Kreativität</h3>
        </div>
        <div class="flex flex-wrap gap-3">
          {creativeSkills.map((skill) => (
            <span class="skill-pill">
              <span class="skill-pill-dot" aria-hidden="true"></span>
              {skill}
            </span>
          ))}
        </div>
      </div>

    </div>

    <!-- Studium Box -->
    <div
      class="mt-12 rounded-3xl p-8 md:p-10 fade-up"
      style="background: rgba(8,31,91,0.2); border: 1px solid rgba(255,255,255,0.05); backdrop-filter: blur(10px);"
    >
      <div class="flex flex-wrap items-start gap-8">
        <div class="flex-1 min-w-[150px]">
          <div class="text-xs font-semibold tracking-[0.18em] uppercase mb-3" style="color: #C9A84C;">Studium</div>
          <h4 class="text-white font-semibold text-lg mb-1">B.A. E-Commerce</h4>
          <p class="text-sm font-light" style="color: rgba(255,255,255,0.4);">THWS · 7. Semester</p>
        </div>
        <div class="flex-1 min-w-[150px]">
          <div class="text-xs font-semibold tracking-[0.18em] uppercase mb-3" style="color: #C9A84C;">Studieninhalte</div>
          <ul class="text-sm font-light space-y-1.5" style="color: rgba(255,255,255,0.45);">
            <li>→ BWL, Marketing, Wirtschaftsrecht</li>
            <li>→ Web-Technologien, UX, Shop-Systeme</li>
            <li>→ Web Analytics, Conversion-Optimierung</li>
            <li>→ Plattformstrategien, Multichannel</li>
          </ul>
        </div>
        <div class="flex-1 min-w-[150px]">
          <div class="text-xs font-semibold tracking-[0.18em] uppercase mb-3" style="color: #C9A84C;">Praxis</div>
          <ul class="text-sm font-light space-y-1.5" style="color: rgba(255,255,255,0.45);">
            <li>→ Online Marketer @ Top Leader Academy</li>
            <li>→ Head of Social Media @ JUMIKO Franken</li>
            <li>→ Jugendarbeit Dekanat Naila</li>
          </ul>
        </div>
      </div>
    </div>

  </div>
</section>
