---
const marketingSkills = [
  'SEO / SEA',
  'Content Marketing',
  'Web Analytics',
  'Shopify / WooCommerce',
  'Social Media Marketing',
  'E-Mail-Marketing',
  'Conversion Optimierung',
  'Google Analytics',
  'Multichannel-Strategie',
];

const creativeSkills = [
  'DaVinci Resolve',
  'Video Editing',
  'Social Content',
  'Storytelling',
  'Projektmanagement',
  'Agile Methoden',
  'Podcast-Produktion',
  'Community Building',
];
---

<section
  id="skills"
  class="py-24 md:py-32 bg-[#040E06]"
  aria-labelledby="skills-headline"
>
  <div class="max-w-7xl mx-auto px-6 md:px-12">

    <!-- Header -->
    <div class="mb-16 md:flex md:items-end md:justify-between">
      <div>
        <div class="fade-up mb-4">
          <span class="text-accent-primary text-xs font-semibold tracking-[0.2em] uppercase">Was ich kann</span>
        </div>
        <h2
          id="skills-headline"
          class="font-headline text-[clamp(3rem,8vw,6rem)] leading-none text-white fade-up"
          style="transition-delay: 0.05s;"
        >
          SKILLS &<br />
          <span class="text-accent-primary">TOOLS</span>
        </h2>
      </div>
      <p class="text-text-muted max-w-xs mt-4 md:mt-0 fade-up" style="transition-delay: 0.1s;">
        Aus Studium, Praxis und echter Leidenschaft gewachsen.
      </p>
    </div>

    <!-- Two columns -->
    <div class="grid md:grid-cols-2 gap-12 lg:gap-20">

      <!-- E-Commerce & Marketing -->
      <div class="fade-up" style="transition-delay: 0.1s;">
        <div class="flex items-center gap-3 mb-8">
          <div
            class="w-8 h-8 rounded-lg flex items-center justify-center text-sm"
            style="background: rgba(201,168,76,0.15);"
            aria-hidden="true"
          >
            📊
          </div>
          <h3 class="text-white font-semibold text-lg">E-Commerce & Marketing</h3>
        </div>
        <div class="flex flex-wrap gap-3">
          {marketingSkills.map((skill) => (
            <span class="skill-pill">{skill}</span>
          ))}
        </div>
      </div>

      <!-- Content & Kreativ -->
      <div class="fade-up" style="transition-delay: 0.15s;">
        <div class="flex items-center gap-3 mb-8">
          <div
            class="w-8 h-8 rounded-lg flex items-center justify-center text-sm"
            style="background: rgba(201,168,76,0.15);"
            aria-hidden="true"
          >
            🎬
          </div>
          <h3 class="text-white font-semibold text-lg">Content & Kreativ</h3>
        </div>
        <div class="flex flex-wrap gap-3">
          {creativeSkills.map((skill) => (
            <span class="skill-pill">{skill}</span>
          ))}
        </div>
      </div>

    </div>

    <!-- Study context box -->
    <div
      class="mt-16 rounded-2xl p-8 fade-up"
      style="background: linear-gradient(135deg, #061108 0%, #110E1C 100%); border: 1px solid rgba(201,168,76,0.12);"
      style-delay="0.2s"
    >
      <div class="flex flex-wrap items-start gap-6">
        <div class="flex-1 min-w-[200px]">
          <div class="text-accent-primary text-xs font-semibold tracking-widest uppercase mb-2">Studium</div>
          <h4 class="text-white font-semibold text-xl mb-2">B.A. E-Commerce</h4>
          <p class="text-text-muted text-sm">THWS · ca. 4. Semester</p>
        </div>
        <div class="flex-1 min-w-[200px]">
          <div class="text-accent-primary text-xs font-semibold tracking-widest uppercase mb-2">Studieninhalte</div>
          <ul class="text-text-muted text-sm space-y-1.5">
            <li>→ BWL, Marketing, Wirtschaftsrecht</li>
            <li>→ Web-Technologien, UX, Shop-Systeme</li>
            <li>→ Web Analytics, Conversion-Optimierung</li>
            <li>→ Plattformstrategien, Multichannel, B2B/B2C</li>
            <li>→ Supply Chain, Fulfillment, Zahlungssysteme</li>
          </ul>
        </div>
        <div class="flex-1 min-w-[200px]">
          <div class="text-accent-primary text-xs font-semibold tracking-widest uppercase mb-2">Praxis</div>
          <ul class="text-text-muted text-sm space-y-1.5">
            <li>→ Online Marketer @ Top Leader Academy</li>
            <li>→ Video Creator @ JUMIKO Franken</li>
            <li>→ Jugendarbeit Dekanat Naila</li>
          </ul>
        </div>
      </div>
    </div>

  </div>
</section>
