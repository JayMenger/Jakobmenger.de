---
const marketingSkills = [
  'SEO / SEA',
  'Content Marketing',
  'Web Analytics',
  'Shopify / WooCommerce',
  'Social Media Marketing',
  'E-Mail-Marketing',
  'Conversion Optimierung',
  'Google Analytics',
  'Multichannel-Strategie',
];

const creativeSkills = [
  'DaVinci Resolve',
  'Video Editing',
  'Social Content',
  'Storytelling',
  'Projektmanagement',
  'Agile Methoden',
  'Podcast-Produktion',
  'Community Building',
];
---

<section
  id="skills"
  class="relative py-28 md:py-36 overflow-hidden"
  style="background: #050C18;"
  aria-labelledby="skills-headline"
>
  <!-- Atmosphäre -->
  <div
    class="absolute pointer-events-none"
    style="top: 0; right: -10%; width: 600px; height: 600px; background: radial-gradient(circle, rgba(201,168,76,0.06) 0%, transparent 65%); filter: blur(70px);"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12">

    <!-- Header -->
    <div class="mb-16 md:flex md:items-end md:justify-between">
      <div>
        <div class="fade-up mb-5">
          <span class="text-xs font-semibold tracking-[0.22em] uppercase" style="color: #C9A84C;">Was ich kann</span>
        </div>
        <h2
          id="skills-headline"
          class="font-headline text-[clamp(3rem,8vw,6rem)] leading-none text-white fade-up"
          style="transition-delay: 0.06s;"
        >
          SKILLS &<br />
          <span style="color: #C9A84C;">TOOLS</span>
        </h2>
      </div>
      <p class="max-w-xs mt-4 md:mt-0 font-light fade-up" style="color: rgba(255,255,255,0.4); transition-delay: 0.1s;">
        Aus Studium, Praxis und echter Leidenschaft gewachsen.
      </p>
    </div>

    <!-- Two columns -->
    <div class="grid md:grid-cols-2 gap-12 lg:gap-20">

      <div class="fade-up" style="transition-delay: 0.1s;">
        <div class="flex items-center gap-3 mb-8">
          <div
            class="w-8 h-8 rounded-xl flex items-center justify-center text-sm"
            style="background: rgba(8,31,91,0.5); border: 1px solid rgba(255,255,255,0.06);"
            aria-hidden="true"
          >📊</div>
          <h3 class="text-white font-medium text-base tracking-wide">E-Commerce & Marketing</h3>
        </div>
        <div class="flex flex-wrap gap-2.5">
          {marketingSkills.map((skill) => (
            <span class="skill-pill">{skill}</span>
          ))}
        </div>
      </div>

      <div class="fade-up" style="transition-delay: 0.15s;">
        <div class="flex items-center gap-3 mb-8">
          <div
            class="w-8 h-8 rounded-xl flex items-center justify-center text-sm"
            style="background: rgba(8,31,91,0.5); border: 1px solid rgba(255,255,255,0.06);"
            aria-hidden="true"
          >🎬</div>
          <h3 class="text-white font-medium text-base tracking-wide">Content & Kreativ</h3>
        </div>
        <div class="flex flex-wrap gap-2.5">
          {creativeSkills.map((skill) => (
            <span class="skill-pill">{skill}</span>
          ))}
        </div>
      </div>

    </div>

    <!-- Studium Box -->
    <div
      class="mt-16 rounded-3xl p-8 md:p-10 fade-up"
      style="background: rgba(8,31,91,0.2); border: 1px solid rgba(255,255,255,0.05); backdrop-filter: blur(10px);"
    >
      <div class="flex flex-wrap items-start gap-8">
        <div class="flex-1 min-w-[150px]">
          <div class="text-xs font-semibold tracking-[0.18em] uppercase mb-3" style="color: #C9A84C;">Studium</div>
          <h4 class="text-white font-semibold text-lg mb-1">B.A. E-Commerce</h4>
          <p class="text-sm font-light" style="color: rgba(255,255,255,0.4);">THWS · ca. 4. Semester</p>
        </div>
        <div class="flex-1 min-w-[150px]">
          <div class="text-xs font-semibold tracking-[0.18em] uppercase mb-3" style="color: #C9A84C;">Studieninhalte</div>
          <ul class="text-sm font-light space-y-1.5" style="color: rgba(255,255,255,0.45);">
            <li>→ BWL, Marketing, Wirtschaftsrecht</li>
            <li>→ Web-Technologien, UX, Shop-Systeme</li>
            <li>→ Web Analytics, Conversion-Optimierung</li>
            <li>→ Plattformstrategien, Multichannel</li>
            <li>→ Supply Chain, Fulfillment</li>
          </ul>
        </div>
        <div class="flex-1 min-w-[150px]">
          <div class="text-xs font-semibold tracking-[0.18em] uppercase mb-3" style="color: #C9A84C;">Praxis</div>
          <ul class="text-sm font-light space-y-1.5" style="color: rgba(255,255,255,0.45);">
            <li>→ Online Marketer @ Top Leader Academy</li>
            <li>→ Video Creator @ JUMIKO Franken</li>
            <li>→ Jugendarbeit Dekanat Naila</li>
          </ul>
        </div>
      </div>
    </div>

  </div>
</section>
