---
const facts = [
  { icon: '📍', label: 'Würzburg' },
  { icon: '📚', label: '4. Semester E-Commerce' },
  { icon: '💡', label: 'JESUS 1ST' },
];
---

<section
  id="ueber"
  class="relative py-28 md:py-36 overflow-hidden"
  style="background: #0C1629;"
  aria-labelledby="ueber-headline"
>
  <!-- Atmosphärischer Blob -->
  <div
    class="absolute pointer-events-none"
    style="top: -10%; right: -10%; width: 700px; height: 700px; background: radial-gradient(circle, rgba(201,168,76,0.07) 0%, transparent 65%); filter: blur(70px);"
    aria-hidden="true"
  ></div>
  <div
    class="absolute pointer-events-none"
    style="bottom: -10%; left: -5%; width: 600px; height: 600px; background: radial-gradient(circle, rgba(8,31,91,0.4) 0%, transparent 65%); filter: blur(60px);"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12">
    <div class="grid md:grid-cols-2 gap-16 lg:gap-24 items-center">

      <!-- Linke Seite: Zitat-Karte -->
      <div class="fade-up">
        <div
          class="relative aspect-square max-w-[400px] mx-auto rounded-3xl overflow-hidden flex flex-col justify-end p-10"
          style="background: linear-gradient(160deg, rgba(8,31,91,0.3) 0%, rgba(5,12,24,0.8) 100%); border: 1px solid rgba(201,168,76,0.1);"
        >
          <!-- Großes JM im Hintergrund -->
          <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none" aria-hidden="true">
            <span class="font-headline text-[11rem] leading-none" style="color: rgba(201,168,76,0.05);">JM</span>
          </div>

          <!-- Gold glow oben rechts -->
          <div
            class="absolute top-0 right-0 w-40 h-40 rounded-full pointer-events-none"
            style="background: radial-gradient(circle at top right, rgba(201,168,76,0.1) 0%, transparent 70%); filter: blur(20px);"
            aria-hidden="true"
          ></div>

          <!-- Zitat -->
          <div class="relative z-10">
            <blockquote
              class="text-white/80 text-xl leading-relaxed italic font-light"
              style="border-left: 2px solid rgba(201,168,76,0.5); padding-left: 1.25rem;"
            >
              „Christus in euch, die Hoffnung der Herrlichkeit."
            </blockquote>
            <cite class="block text-sm mt-4 not-italic tracking-[0.15em]" style="color: rgba(201,168,76,0.6);">Kolosser 1,27</cite>
          </div>
        </div>
      </div>

      <!-- Rechte Seite: Text -->
      <div>
        <div class="fade-up mb-5">
          <span class="text-xs font-semibold tracking-[0.22em] uppercase" style="color: #C9A84C;">Über mich</span>
        </div>

        <h2
          id="ueber-headline"
          class="font-headline text-[clamp(3rem,7vw,5.5rem)] leading-[0.95] text-white fade-up"
          style="transition-delay: 0.06s;"
        >
          WER<br />
          <span style="color: #C9A84C;">ICH BIN</span>
        </h2>

        <div class="mt-9 space-y-5 font-light text-lg leading-relaxed fade-up" style="color: rgba(255,255,255,0.55); transition-delay: 0.1s;">
          <p>
            Ich bin Jakob — Student, Marketer, Creator und Christ. Ich lebe in der Schnittstelle zwischen digitalem Business und echtem Leben: Ich lerne jeden Tag dazu, probiere aus, mache Fehler und wachse.
          </p>
          <p>
            Mein Antrieb? Kolosser 1,27 — Christus in mir, die Hoffnung der Herrlichkeit. Was das konkret bedeutet, siehst du in allem, was ich tue.
          </p>
        </div>

        <!-- Quick facts -->
        <div class="mt-10 flex flex-wrap gap-3 fade-up" style="transition-delay: 0.18s;">
          {facts.map((fact) => (
            <span
              class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium"
              style="background: rgba(201,168,76,0.08); border: 1px solid rgba(201,168,76,0.18); color: #E8C87A;"
            >
              <span aria-hidden="true">{fact.icon}</span>
              {fact.label}
            </span>
          ))}
        </div>

        <!-- Stats -->
        <div class="mt-14 grid grid-cols-3 gap-6 fade-up" style="transition-delay: 0.24s; border-top: 1px solid rgba(255,255,255,0.06); padding-top: 2rem;">
          {[
            { value: '4.', label: 'Semester' },
            { value: '2+', label: 'Jahre Erfahrung' },
            { value: '∞', label: 'Motivation' },
          ].map((stat) => (
            <div class="text-center">
              <div class="font-headline text-4xl" style="color: #C9A84C;">{stat.value}</div>
              <div class="text-xs mt-1.5 tracking-wide uppercase" style="color: rgba(255,255,255,0.35);">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
