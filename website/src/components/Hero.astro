---
---

<section
  id="hero"
  class="relative min-h-screen flex items-center overflow-hidden radial-glow"
  aria-label="Hero"
>
  <!-- Subtle grid lines -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background-image: linear-gradient(rgba(201,168,76,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(201,168,76,0.025) 1px, transparent 1px); background-size: 80px 80px;"
    aria-hidden="true"
  ></div>

  <!-- Top-right corner glow -->
  <div
    class="absolute top-0 right-0 w-[600px] h-[600px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(201,168,76,0.08) 0%, transparent 70%); transform: translate(30%, -30%);"
    aria-hidden="true"
  ></div>

  <!-- BRG accent strip left -->
  <div class="absolute left-0 top-0 bottom-0 w-1 bg-gradient-to-b from-transparent via-[#004225] to-transparent opacity-60" aria-hidden="true"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 w-full pt-28 pb-20">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Left: Text -->
      <div class="order-2 md:order-1">

        <!-- JESUS 1ST badge -->
        <div class="mb-6 fade-up" style="transition-delay: 0.05s;">
          <span class="badge-gold">
            <svg class="w-3 h-3 fill-current" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M8 1.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13ZM0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8Zm8-3.5a.5.5 0 0 1 .5.5v2.5H11a.5.5 0 0 1 0 1H8.5V11a.5.5 0 0 1-1 0V8.5H5a.5.5 0 0 1 0-1h2.5V5a.5.5 0 0 1 .5-.5Z"/>
            </svg>
            JESUS 1ST
          </span>
        </div>

        <!-- Main headline -->
        <div class="fade-up" style="transition-delay: 0.1s;">
          <h1 class="font-headline leading-none">
            <span
              class="block text-[clamp(5rem,14vw,10rem)] text-white tracking-wide"
            >
              JAKOB
            </span>
            <span
              class="block text-[clamp(5rem,14vw,10rem)] tracking-wide shimmer-text"
            >
              MENGER
            </span>
          </h1>
        </div>

        <!-- Subline -->
        <div class="fade-up mt-4" style="transition-delay: 0.2s;">
          <p class="text-sm md:text-base font-body font-medium tracking-[0.25em] text-text-muted uppercase">
            E-Commerce · Marketing · Content
          </p>
        </div>

        <!-- Statement -->
        <div class="fade-up mt-8 max-w-md" style="transition-delay: 0.3s;">
          <p class="text-white/70 text-lg leading-relaxed">
            Student, Marketer und Christ — ich verbinde digitales Business mit echtem Antrieb.
          </p>
        </div>

        <!-- CTAs -->
        <div class="fade-up mt-10 flex flex-wrap gap-4" style="transition-delay: 0.4s;">
          <a
            href="#ueber"
            class="px-7 py-3.5 font-semibold rounded-full text-sm transition-all duration-200"
            style="background: #C9A84C; color: #040E06;"
            onmouseover="this.style.background='#E8C87A'"
            onmouseout="this.style.background='#C9A84C'"
          >
            Mehr erfahren →
          </a>
          <a
            href="#kontakt"
            class="px-7 py-3.5 border font-medium rounded-full text-sm transition-all duration-200 text-white/70 hover:text-accent-primary"
            style="border-color: rgba(201,168,76,0.3);"
            onmouseover="this.style.borderColor='rgba(201,168,76,0.7)'"
            onmouseout="this.style.borderColor='rgba(201,168,76,0.3)'"
          >
            Kontakt
          </a>
        </div>
      </div>

      <!-- Right: Photo -->
      <div class="order-1 md:order-2 flex justify-center md:justify-end fade-up" style="transition-delay: 0.15s;">
        <div class="relative">
          <!-- Outer glow -->
          <div
            class="absolute inset-0 rounded-full pointer-events-none"
            style="background: radial-gradient(circle, rgba(201,168,76,0.2) 0%, transparent 70%); transform: scale(1.3);"
            aria-hidden="true"
          ></div>

          <!-- Rotating BRG+Gold frame -->
          <div class="photo-frame">
            <div class="w-[280px] h-[280px] md:w-[360px] md:h-[360px] rounded-full bg-[#040E06] flex items-center justify-center overflow-hidden">
              <img
                src="/assets/foto.jpg"
                alt="Jakob Menger"
                class="w-full h-full object-cover rounded-full"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                loading="eager"
              />
              <div
                class="w-full h-full rounded-full flex flex-col items-center justify-center"
                style="display:none; background: linear-gradient(135deg, #061108 0%, #040E06 100%); border: 1px solid rgba(201,168,76,0.15);"
                aria-label="Foto-Platzhalter"
              >
                <span class="font-headline text-7xl leading-none" style="color: #C9A84C;">JM</span>
                <span class="text-text-muted text-xs mt-2 tracking-widest">FOTO FOLGT</span>
              </div>
            </div>
          </div>

          <!-- Floating badge -->
          <div
            class="absolute -bottom-4 left-1/2 -translate-x-1/2 badge-gold whitespace-nowrap"
            style="font-size: 0.7rem;"
          >
            E-Commerce Student
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 bounce" aria-hidden="true">
    <span class="text-text-muted text-xs tracking-widest uppercase">Scroll</span>
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="#C9A84C">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>
