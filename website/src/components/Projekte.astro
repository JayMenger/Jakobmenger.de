---
const projects = [
  {
    name: 'Top Leader Academy',
    category: 'Online Marketing · Video · Podcast-Produktion',
    description:
      'Als Online Marketer unterstütze ich die Top Leader Academy mit digitalen Marketingmaßnahmen und produziere Videos sowie den Podcast von Klaus-Peter Grießhammer — ehemaliger CHRO und Topmanager mit 25 Jahren Erfahrung.',
    link: 'https://topleader.de',
    linkLabel: 'topleader.de',
    tags: ['Online Marketing', 'Video', 'Podcast'],
    featured: true,
  },
  {
    name: 'JUMIKO Franken',
    category: 'Head of Social Media · Video · Content',
    description:
      'Als Head of Social Media verantworte ich den gesamten Social-Media-Auftritt der Jugendmissionskonferenz Franken — Content-Strategie, Videoproduktion und Community. Ein Event, das junge Christen mit Mission verbindet und jedes Jahr Hunderte bewegt.',
    link: 'https://jumiko-frankenwald.de',
    linkLabel: 'jumiko-frankenwald.de',
    tags: ['Head of Social Media', 'Video', 'Content-Strategie'],
    featured: false,
  },
];
---

<section
  id="projekte"
  class="py-28 md:py-36"
  style="background: #F7F8FF;"
  aria-labelledby="projekte-headline"
>
  <div class="max-w-7xl mx-auto px-6 md:px-12">

    <div class="mb-20 text-center">
      <div class="fade-up mb-5">
        <span class="text-xs font-semibold tracking-[0.22em] uppercase" style="color: #1A3A7A;">Wo ich aktiv bin</span>
      </div>
      <h2
        id="projekte-headline"
        class="font-headline text-[clamp(3rem,8vw,6rem)] leading-none text-[#050C18] fade-up"
        style="transition-delay: 0.06s;"
      >
        MEINE<br />
        <span style="background: linear-gradient(90deg, #8B6914, #C9A84C, #8B6914); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">PROJEKTE</span>
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 gap-8">
      {projects.map((project, i) => (
        <article
          class="card-hover fade-up rounded-3xl overflow-hidden flex flex-col bg-white"
          style={`box-shadow: 0 2px 20px rgba(8,31,91,${project.featured ? '0.1' : '0.05'}), 0 8px 40px rgba(8,31,91,${project.featured ? '0.08' : '0.03'}); transition-delay: ${i * 0.1}s;`}
        >
          <!-- Top bar: navy → gold gradient -->
          <div
            class="h-1 w-full"
            style="background: linear-gradient(90deg, #081F5B, #C9A84C 60%, #E8C87A);"
            aria-hidden="true"
          ></div>

          <div class="p-8 md:p-10 flex flex-col flex-1">
            <p class="text-xs font-semibold tracking-[0.18em] uppercase mb-4" style="color: #1A3A7A;">
              {project.category}
            </p>
            <h3 class="font-headline text-3xl md:text-4xl mb-4" style="color: #050C18;">{project.name}</h3>
            <p class="text-base leading-relaxed flex-1 font-light" style="color: rgba(5,12,24,0.6);">{project.description}</p>

            <div class="mt-7 flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span
                  class="px-3 py-1 rounded-full text-xs font-medium"
                  style="background: rgba(8,31,91,0.07); color: #1A3A7A;"
                >
                  {tag}
                </span>
              ))}
            </div>

            <div class="mt-8 pt-6" style="border-top: 1px solid rgba(5,12,24,0.07);">
              <a
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-sm font-medium transition-all duration-200 group"
                style="color: #1A3A7A;"
                onmouseover="this.style.color='#C9A84C'"
                onmouseout="this.style.color='#1A3A7A'"
              >
                {project.linkLabel}
                <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
