---
const projects = [
  {
    name: 'JUMIKO Franken',
    category: 'Head of Social Media · Video · Content',
    description:
      'Als Head of Social Media verantworte ich den gesamten Social-Media-Auftritt der Jugendmissionskonferenz Franken — Content-Strategie, Videoproduktion und Community. Ein Event, das junge Christen mit Mission verbindet und jedes Jahr Hunderte bewegt.',
    link: 'https://jumiko-frankenwald.de',
    linkLabel: 'jumiko-frankenwald.de →',
    tags: ['Head of Social Media', 'Video', 'Content-Strategie'],
    accent: true,
  },
  {
    name: 'Top Leader Academy',
    category: 'Online Marketing · Video · Podcast-Produktion',
    description:
      'Als Online Marketer unterstütze ich die Top Leader Academy mit digitalen Marketingmaßnahmen und produziere Videos sowie den Podcast von Klaus-Peter Grießhammer — ehemaliger CHRO und Topmanager mit 25 Jahren Erfahrung.',
    link: 'https://topleader.de',
    linkLabel: 'topleader.de →',
    tags: ['Online Marketing', 'Video', 'Podcast'],
    accent: false,
  },
];
---

<section
  id="projekte"
  class="py-24 md:py-32 bg-[#F0F8F2]"
  aria-labelledby="projekte-headline"
>
  <div class="max-w-7xl mx-auto px-6 md:px-12">

    <div class="mb-16 text-center">
      <div class="fade-up mb-4">
        <span class="text-brg text-xs font-semibold tracking-[0.2em] uppercase">Wo ich aktiv bin</span>
      </div>
      <h2
        id="projekte-headline"
        class="font-headline text-[clamp(3rem,8vw,6rem)] leading-none text-[#040E06] fade-up"
        style="transition-delay: 0.05s;"
      >
        MEINE<br />
        <span style="background: linear-gradient(90deg, #8B6914, #C9A84C, #8B6914); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">
          PROJEKTE
        </span>
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {projects.map((project, i) => (
        <article
          class="card-hover fade-up rounded-2xl overflow-hidden flex flex-col bg-white"
          style={`border: 1px solid rgba(201,168,76,${project.accent ? '0.35' : '0.15'}); box-shadow: 0 4px 32px rgba(201,168,76,${project.accent ? '0.1' : '0.04'}); transition-delay: ${i * 0.1}s;`}
        >
          <!-- Top accent bar -->
          <div
            class="h-1.5 w-full"
            style="background: linear-gradient(90deg, #004225, #C9A84C, #004225);"
            aria-hidden="true"
          ></div>

          <div class="p-8 flex flex-col flex-1">
            <div class="text-brg text-xs font-semibold tracking-widest uppercase mb-3">
              {project.category}
            </div>
            <h3 class="font-headline text-3xl text-[#040E06] mb-4">{project.name}</h3>
            <p class="text-[#040E06]/65 leading-relaxed flex-1">{project.description}</p>

            <div class="mt-6 flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span
                  class="px-3 py-1 rounded-full text-xs font-semibold"
                  style="background: rgba(0,66,37,0.08); color: #004225;"
                >
                  {tag}
                </span>
              ))}
            </div>

            <div class="mt-8 pt-6 border-t border-[#040E06]/10">
              <a
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 font-semibold text-sm transition-all duration-200 hover:gap-3"
                style="color: #004225;"
              >
                {project.linkLabel}
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
