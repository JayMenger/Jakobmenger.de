---
---

<section
  id="kontakt"
  class="py-24 md:py-32"
  style="background: #0D1810;"
  aria-labelledby="kontakt-headline"
>
  <div class="max-w-4xl mx-auto px-6 md:px-12 text-center">

    <div class="fade-up mb-6">
      <span class="badge-gold">Kontakt</span>
    </div>

    <h2
      id="kontakt-headline"
      class="font-headline text-[clamp(3.5rem,10vw,8rem)] leading-none text-white fade-up"
      style="transition-delay: 0.05s;"
    >
      LET'S<br />
      <span class="glow-pulse">CONNECT.</span>
    </h2>

    <p class="mt-6 text-text-muted text-xl fade-up" style="transition-delay: 0.1s;">
      Projekt? Frage? Einfach melden.
    </p>

    <div class="mt-12 flex flex-wrap justify-center gap-4 fade-up" style="transition-delay: 0.15s;">
      <!-- LinkedIn -->
      <a
        href="https://www.linkedin.com/in/jakobmenger/"
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-3 px-8 py-4 rounded-full font-semibold text-sm transition-all duration-200"
        style="background: #0A66C2; color: #ffffff;"
        onmouseover="this.style.background='#085299'"
        onmouseout="this.style.background='#0A66C2'"
        aria-label="Jakob Menger auf LinkedIn"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        Auf LinkedIn verbinden
      </a>

      <!-- E-Mail -->
      <a
        href="mailto:jakob.menger@icloud.com"
        class="inline-flex items-center gap-3 px-8 py-4 rounded-full font-semibold text-sm transition-all duration-200 border"
        style="border-color: rgba(201,168,76,0.4); color: #C9A84C; background: transparent;"
        onmouseover="this.style.background='rgba(201,168,76,0.1)'"
        onmouseout="this.style.background='transparent'"
        aria-label="E-Mail an jakob.menger@icloud.com"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        jakob.menger@icloud.com
      </a>
    </div>

    <div class="mt-12 fade-up" style="transition-delay: 0.2s;">
      <span class="text-text-muted text-sm tracking-widest">jakobmenger.de</span>
    </div>

    <div
      class="mt-16 mx-auto w-32 h-px fade-up"
      style="background: linear-gradient(90deg, transparent, rgba(201,168,76,0.4), transparent); transition-delay: 0.25s;"
      aria-hidden="true"
    ></div>

  </div>
</section>
