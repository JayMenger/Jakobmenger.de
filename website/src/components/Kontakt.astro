---
---

<section
  id="kontakt"
  aria-labelledby="kontakt-headline"
  style="
    background: #0f172a;
    border-top: 1px solid rgba(255,255,255,0.12);
    min-height: 90vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 8rem 1.5rem 5rem;
  "
>

  <div style="max-width: 680px; width: 100%; text-align: center;">

    <!-- Headline -->
    <h2
      id="kontakt-headline"
      class="fade-up"
      style="
        font-family: 'Playfair Display', Georgia, serif;
        font-weight: 300;
        font-size: clamp(3rem, 9vw, 7rem);
        letter-spacing: -0.02em;
        line-height: 1.05;
        color: #ffffff;
        margin-bottom: 1.5rem;
      "
    >
      LET'S <span class="shimmer-text">CONNECT.</span>
    </h2>

    <!-- Subline -->
    <p
      class="fade-up"
      style="
        font-family: 'Outfit', sans-serif;
        font-weight: 300;
        font-size: 1.05rem;
        color: rgba(255,255,255,0.45);
        letter-spacing: 0.01em;
        margin-bottom: 4rem;
        transition-delay: 0.08s;
      "
    >
      Lass uns gemeinsam an echten Ergebnissen arbeiten.
    </p>

    <!-- Buttons -->
    <div
      class="fade-up"
      style="
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 1rem;
        margin-bottom: 5rem;
        transition-delay: 0.16s;
      "
    >

      <!-- LinkedIn – identisch zum "Mehr erfahren"-Button im Hero -->
      <a
        href="https://www.linkedin.com/in/jakobmenger/"
        target="_blank"
        rel="noopener noreferrer"
        class="connect-btn-primary"
        style="background: #C9A84C; color: #050C18;"
        onmouseover="this.style.background='#E8C87A'; this.style.boxShadow='0 0 40px rgba(201,168,76,0.3)'"
        onmouseout="this.style.background='#C9A84C'; this.style.boxShadow='none'"
        aria-label="Jakob Menger auf LinkedIn"
      >
        <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="flex-shrink:0;">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn
      </a>

      <!-- E-Mail -->
      <a
        href="mailto:jakob.menger@icloud.com"
        class="connect-btn"
        aria-label="E-Mail an jakob.menger@icloud.com"
      >
        <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true" style="flex-shrink:0;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        jakob.menger@icloud.com
      </a>

    </div>

  </div>

</section>

<style>
  /* Primär-Button (LinkedIn) – gleiche Geometrie wie Hero "Mehr erfahren" */
  .connect-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 1.1rem 2.75rem;
    border-radius: 999px;
    border: none;
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 0.01em;
    text-decoration: none;
    transition: background 0.3s ease, box-shadow 0.3s ease;
    white-space: nowrap;
  }

  .connect-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 1.1rem 2.25rem;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.2);
    background: transparent;
    color: rgba(255,255,255,0.8);
    font-family: 'Outfit', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    letter-spacing: 0.01em;
    text-decoration: none;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    white-space: nowrap;
  }
  .connect-btn:hover {
    background: rgba(255,255,255,0.07);
    border-color: rgba(255,255,255,0.35);
    color: #ffffff;
  }

  /* Mobile: Buttons volle Breite, gestapelt */
  @media (max-width: 540px) {
    .connect-btn,
    .connect-btn-primary {
      width: 100%;
      justify-content: center;
    }
  }
</style>
