---
---

<section
  id="glaube"
  class="faith-dark relative overflow-hidden"
  style="background: #0f172a;"
  aria-labelledby="glaube-headline"
>

  <!-- Atmosphärische Blobs -->
  <div
    class="absolute pointer-events-none"
    style="top: -20%; left: 50%; transform: translateX(-50%); width: 1000px; height: 700px; background: radial-gradient(ellipse, rgba(201,168,76,0.1) 0%, rgba(8,31,91,0.08) 45%, transparent 70%); filter: blur(80px);"
    aria-hidden="true"
  ></div>
  <div
    class="absolute pointer-events-none"
    style="bottom: -10%; right: -10%; width: 600px; height: 600px; background: radial-gradient(circle, rgba(8,31,91,0.3) 0%, transparent 65%); filter: blur(60px);"
    aria-hidden="true"
  ></div>

  <div class="faith-dark-inner">

    <!-- Symbol -->
    <div class="faith-dark-symbol fade-up" aria-hidden="true">✦</div>

    <!-- Hauptzitat (Bibelvers) -->
    <blockquote
      id="glaube-headline"
      class="fade-up"
      style="transition-delay: 0.06s;"
    >
      „Christus in euch, die Hoffnung der Herrlichkeit."
    </blockquote>

    <!-- Bibelstelle -->
    <p
      class="fade-up"
      style="transition-delay: 0.12s; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(201,168,76,0.55); margin-bottom: 1.75rem;"
    >
      Kolosser 1,27
    </p>

    <!-- Divider -->
    <div
      class="mx-auto mb-8 h-px fade-up"
      style="width: 60px; background: linear-gradient(90deg, transparent, rgba(201,168,76,0.5), transparent); transition-delay: 0.16s;"
      aria-hidden="true"
    ></div>

    <!-- Fließtext -->
    <p class="fade-up" style="transition-delay: 0.2s; color: rgba(255,255,255,0.55); font-size: 0.975rem; line-height: 1.8; font-weight: 300;">
      Das ist mein Fundament, meine Kraft kommt von Jesus!
    </p>

  </div>
</section>
