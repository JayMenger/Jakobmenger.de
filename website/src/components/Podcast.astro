---
---

<section
  id="podcast"
  class="py-28 md:py-36"
  style="background: #F7F8FF;"
  aria-labelledby="podcast-headline"
>
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="grid md:grid-cols-2 gap-16 lg:gap-24 items-center">

      <!-- Links: Cover -->
      <div class="fade-up flex justify-center md:justify-start">
        <div class="relative">
          <div
            class="w-full max-w-[280px] aspect-square rounded-3xl overflow-hidden"
            style="box-shadow: 0 20px 60px rgba(8,31,91,0.15), 0 4px 20px rgba(0,0,0,0.1); border: 1px solid rgba(201,168,76,0.15);"
          >
            <img
              src="/assets/podcast-thumbnail.jpg"
              alt="Top Leader Academy Podcast Cover"
              class="w-full h-full object-cover"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
            <!-- Fallback -->
            <div
              class="w-full h-full flex-col items-center justify-center"
              style="display:none; background: linear-gradient(160deg, #0f172a 0%, #16213b 100%);"
              role="img"
              aria-label="Top Leader Academy Podcast Cover"
            >
              <div class="relative z-10 text-center">
                <svg class="w-12 h-12 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="#C9A84C" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" />
                </svg>
                <div class="font-headline text-white text-xl tracking-widest">PODCAST</div>
                <div class="text-xs tracking-widest mt-1" style="color: #C9A84C;">TOP LEADER ACADEMY</div>
              </div>
            </div>
          </div>

          <!-- Play-Button -->
          <div
            class="absolute -bottom-4 -right-4 w-14 h-14 rounded-full flex items-center justify-center"
            style="background: #C9A84C; box-shadow: 0 8px 30px rgba(201,168,76,0.3);"
            aria-hidden="true"
          >
            <svg class="w-5 h-5 ml-0.5" fill="#050C18" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z" />
            </svg>
          </div>
        </div>
      </div>

      <!-- Rechts: Text -->
      <div>
        <div class="fade-up mb-5">
          <span class="text-xs font-semibold tracking-[0.22em] uppercase" style="color: #1A3A7A;">Audio Content</span>
        </div>

        <h2
          id="podcast-headline"
          class="font-headline text-[clamp(3rem,7vw,5rem)] leading-none text-[#050C18] fade-up"
          style="transition-delay: 0.06s;"
        >
          PODCAST
        </h2>

        <div class="mt-7 space-y-4 font-light leading-relaxed fade-up" style="color: rgba(5,12,24,0.6); transition-delay: 0.1s;">
          <p>
            Der <strong class="font-semibold" style="color: rgba(5,12,24,0.85);">Top Leader Podcast</strong> ist der Podcast von
            <strong class="font-semibold" style="color: rgba(5,12,24,0.85);">Klaus-Peter Grießhammer</strong> — ehemaliger CHRO und
            Topmanager mit über 25 Jahren Erfahrung. Mit dem FOK.US®-System zeigt er wie Führung unter Druck wirklich funktioniert.
          </p>
          <p>
            Ich produziere diesen Podcast — und profitiere selbst enorm von dem Wissen, das Klaus-Peter darin teilt.
          </p>
        </div>

        <!-- Feature list -->
        <ul class="mt-8 space-y-3 fade-up" style="transition-delay: 0.16s;" aria-label="Podcast-Themen">
          {[
            'Leadership & Persönlichkeitsentwicklung',
            'FOK.US® System — neurowissenschaftlich fundiert',
            'Praxiswissen von einem echten CHRO',
          ].map((item) => (
            <li class="flex items-center gap-3">
              <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background: #C9A84C;" aria-hidden="true"></span>
              <span class="text-sm font-light" style="color: rgba(5,12,24,0.65);">{item}</span>
            </li>
          ))}
        </ul>

        <!-- CTA -->
        <div class="mt-10 fade-up" style="transition-delay: 0.22s;">
          <a
            href="https://topleader.de/kostenloses-wissen"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2.5 px-8 py-3.5 rounded-full text-sm font-semibold transition-all duration-300"
            style="background: #C9A84C; color: #050C18;"
            onmouseover="this.style.background='#E8C87A'; this.style.boxShadow='0 0 40px rgba(201,168,76,0.25)'"
            onmouseout="this.style.background='#C9A84C'; this.style.boxShadow='none'"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M8 5v14l11-7z" />
            </svg>
            Podcast anhören
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
