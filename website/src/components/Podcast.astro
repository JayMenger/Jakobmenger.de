---
---

<section
  id="podcast"
  class="py-24 md:py-32 bg-[#F0F8F2]"
  aria-labelledby="podcast-headline"
>
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="grid md:grid-cols-2 gap-16 items-center">

      <!-- Left: Cover art -->
      <div class="fade-up flex justify-center md:justify-start">
        <div class="relative">
          <div
            class="w-[280px] h-[280px] rounded-3xl flex flex-col items-center justify-center shadow-2xl overflow-hidden"
            style="background: linear-gradient(135deg, #040E06 0%, #061108 50%, #040E06 100%); border: 2px solid rgba(201,168,76,0.25);"
            role="img"
            aria-label="Top Leader Academy Podcast Cover"
          >
            <!-- Decorative rings -->
            <div class="absolute inset-0 flex items-center justify-center" aria-hidden="true">
              <div class="w-48 h-48 rounded-full" style="border: 1px solid rgba(201,168,76,0.08);"></div>
              <div class="w-36 h-36 rounded-full absolute" style="border: 1px solid rgba(201,168,76,0.12);"></div>
              <div class="w-20 h-20 rounded-full absolute" style="border: 1px solid rgba(201,168,76,0.18);"></div>
            </div>
            <div class="relative z-10 text-center">
              <div class="text-5xl mb-3" aria-hidden="true">🎙️</div>
              <div class="font-headline text-white text-xl tracking-widest">PODCAST</div>
              <div class="text-xs tracking-widest mt-1" style="color: #C9A84C;">TOP LEADER ACADEMY</div>
            </div>
            <div
              class="absolute bottom-0 left-0 right-0 h-24"
              style="background: linear-gradient(to top, rgba(201,168,76,0.12), transparent);"
              aria-hidden="true"
            ></div>
          </div>

          <!-- Play button -->
          <div
            class="absolute -bottom-5 -right-5 w-16 h-16 rounded-full flex items-center justify-center shadow-lg"
            style="background: #C9A84C;"
            aria-hidden="true"
          >
            <svg class="w-6 h-6 text-[#040E06] ml-0.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z" />
            </svg>
          </div>
        </div>
      </div>

      <!-- Right: Text -->
      <div>
        <div class="fade-up mb-4">
          <span class="text-brg text-xs font-semibold tracking-[0.2em] uppercase">Audio Content</span>
        </div>

        <h2
          id="podcast-headline"
          class="font-headline text-[clamp(3rem,7vw,5rem)] leading-none text-[#040E06] fade-up"
          style="transition-delay: 0.05s;"
        >
          PODCAST
        </h2>

        <div class="mt-6 space-y-4 text-[#040E06]/65 text-base leading-relaxed fade-up" style="transition-delay: 0.1s;">
          <p>
            Der <strong class="text-[#040E06]/85 font-semibold">Top Leader Podcast</strong> ist der Podcast von
            <strong class="text-[#040E06]/85 font-semibold">Klaus-Peter Grießhammer</strong> — ehemaliger CHRO und
            Topmanager mit über 25 Jahren Erfahrung. Mit dem FOK.US®-System, das auf 60.000+ Neurowissenschaftsstudien
            basiert, zeigt er wie Führung unter Druck wirklich funktioniert.
          </p>
          <p>
            Ich produziere diesen Podcast — und profitiere selbst enorm von dem Wissen, das Klaus-Peter darin teilt.
            Leadership, Personal Branding, digitales Business — direkt von jemandem, der es gelebt hat.
          </p>
        </div>

        <!-- Feature list -->
        <ul class="mt-8 space-y-3 fade-up" style="transition-delay: 0.15s;" aria-label="Podcast-Themen">
          {[
            'Leadership & Persönlichkeitsentwicklung',
            'FOK.US® System — neurowissenschaftlich fundiert',
            'Praxiswissen von einem echten CHRO',
          ].map((item) => (
            <li class="flex items-start gap-3">
              <span
                class="mt-1 w-5 h-5 rounded-full flex-shrink-0 flex items-center justify-center"
                style="background: rgba(0,66,37,0.12);"
                aria-hidden="true"
              >
                <svg class="w-2.5 h-2.5" fill="#004225" viewBox="0 0 8 8">
                  <circle cx="4" cy="4" r="3" />
                </svg>
              </span>
              <span class="text-[#040E06]/70">{item}</span>
            </li>
          ))}
        </ul>

        <!-- CTA -->
        <div class="mt-10 fade-up" style="transition-delay: 0.2s;">
          <a
            href="https://topleader.de/kostenloses-wissen"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full text-sm font-semibold transition-all duration-200 text-[#040E06]"
            style="background: #C9A84C;"
            onmouseover="this.style.background='#E8C87A'"
            onmouseout="this.style.background='#C9A84C'"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M8 5v14l11-7z" />
            </svg>
            Podcast anhören →
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
