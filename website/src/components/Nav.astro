---
const navLinks = [
  { label: 'Über mich', href: '#ueber' },
  { label: 'Projekte', href: '#projekte' },
  { label: 'Glaube', href: '#glaube' },
  { label: 'Kontakt', href: '#kontakt' },
];
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 px-6 md:px-12 py-4"
  role="navigation"
  aria-label="Hauptnavigation"
>
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <!-- Logo -->
    <a
      href="#"
      class="font-headline text-3xl text-accent-primary leading-none tracking-widest hover:text-accent-light transition-colors duration-200"
      aria-label="Jakob Menger — Startseite"
    >
      JM
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-sm font-medium text-white/80 hover:text-accent-primary tracking-wide transition-colors duration-200"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="#kontakt"
          class="ml-2 px-5 py-2 bg-accent-primary text-white text-sm font-semibold rounded-full hover:bg-accent-light hover:text-[#050C18] transition-all duration-200"
        >
          Kontakt
        </a>
      </li>
    </ul>

    <!-- Burger button (mobile) -->
    <button
      id="burger"
      class="md:hidden flex flex-col gap-1.5 p-2 rounded focus:outline-none focus:ring-2 focus:ring-accent-primary"
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="block w-6 h-0.5 bg-white rounded transition-all"></span>
      <span class="block w-6 h-0.5 bg-white rounded transition-all"></span>
      <span class="block w-4 h-0.5 bg-accent-primary rounded transition-all"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden absolute top-full left-0 right-0 bg-[#050C18]/98 border-t border-accent-primary/20 px-6 py-6 backdrop-blur-md"
    role="menu"
  >
    <ul class="flex flex-col gap-4">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="block text-lg font-medium text-white hover:text-accent-primary transition-colors duration-200 py-1"
            role="menuitem"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2 border-t border-white/10">
        <a
          href="#kontakt"
          class="inline-block px-6 py-3 bg-accent-primary text-white font-semibold rounded-full hover:bg-accent-light hover:text-[#050C18] transition-all duration-200"
          role="menuitem"
        >
          Kontakt →
        </a>
      </li>
    </ul>
  </div>
</nav>
