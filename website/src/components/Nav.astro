---
// Desktop: ohne Kontakt (der wird als CTA-Button gezeigt)
const desktopLinks = [
  { label: 'Über mich', href: '#ueber' },
  { label: 'Projekte', href: '#projekte' },
  { label: 'Skills', href: '#skills' },
];

// Mobile: Kontakt als normaler Menüpunkt im Burger-Menü
const mobileLinks = [
  { label: 'Über mich', href: '#ueber' },
  { label: 'Projekte', href: '#projekte' },
  { label: 'Skills', href: '#skills' },
  { label: 'Kontakt', href: '#kontakt' },
];
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 px-6 md:px-12 py-4 md:py-[28px]"
  role="navigation"
  aria-label="Hauptnavigation"
>
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <!-- Logo -->
    <a
      href="#"
      class="font-headline leading-none hover:opacity-80 transition-opacity duration-200"
      style="color: #C9A84C; font-size: 1.75rem; letter-spacing: 0.05em;"
      aria-label="Jakob Menger — Startseite"
    >
      JM
    </a>

    <!-- Desktop links (Über mich · Projekte · Glaube + Kontakt-CTA) -->
    <ul class="hidden md:flex items-center gap-9">
      {desktopLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-base font-medium text-white/80 hover:text-accent-primary tracking-wide transition-colors duration-200"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="#kontakt"
          class="ml-2 px-7 py-3 bg-accent-primary text-white text-base font-semibold rounded-full hover:bg-accent-light hover:text-[#050C18] transition-all duration-200"
        >
          Kontakt
        </a>
      </li>
    </ul>

    <!-- Burger button (mobile) – mind. 44×44px Touch-Target -->
    <button
      id="burger"
      class="md:hidden flex flex-col justify-center items-center gap-1.5 rounded focus:outline-none focus:ring-2 focus:ring-accent-primary"
      style="min-width: 44px; min-height: 44px; padding: 10px;"
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="block w-6 h-0.5 bg-white rounded transition-all"></span>
      <span class="block w-6 h-0.5 bg-white rounded transition-all"></span>
      <span class="block w-4 h-0.5 bg-accent-primary rounded transition-all"></span>
    </button>
  </div>

  <!-- Mobile menu – Kontakt nur hier als normaler Textlink -->
  <div
    id="mobile-menu"
    class="hidden md:hidden fixed left-0 right-0 w-full z-[49] border-t border-accent-primary/20 px-6 py-6"
    style="background: rgba(15, 23, 42, 0.97); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);"
    role="menu"
  >
    <ul class="flex flex-col gap-4">
      {mobileLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="block text-lg font-medium text-white hover:text-accent-primary transition-colors duration-200 py-1"
            role="menuitem"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>
